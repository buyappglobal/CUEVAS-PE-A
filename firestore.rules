rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // An admin is anyone who is in the admins collection OR has an authorized email
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.matches('(?i)holasolonet@gmail\\.com') || 
        request.auth.token.email.matches('(?i)caballerovazquezrafael@gmail\\.com') || 
        request.auth.token.email.matches('(?i)taquilla@cuevas\\.com') ||
        request.auth.token.email.matches('(?i)admin@cuevasdealajar\\.com') ||
        request.auth.token.email.matches('(?i)cuevasdealajar@gmail\\.com')
      );
    }

    match /admins/{adminId} {
      // Anyone signed in can read admins to check if they are one
      allow read: if isSignedIn();
      // Bootstrapping: allow authorized emails to create their own admin document
      allow write: if isSignedIn() && (
        request.auth.token.email.matches('(?i)holasolonet@gmail\\.com') || 
        request.auth.token.email.matches('(?i)caballerovazquezrafael@gmail\\.com') || 
        request.auth.token.email.matches('(?i)taquilla@cuevas\\.com') ||
        request.auth.token.email.matches('(?i)admin@cuevasdealajar\\.com') ||
        request.auth.token.email.matches('(?i)cuevasdealajar@gmail\\.com')
      );
    }

    match /reservations/{reservationId} {
      // Permitimos lectura para que el Panel de Taquilla funcione en modo Bypass
      allow read: if true; 
      allow update, delete: if isAdmin();
      
      // Allow public to create a reservation if it's correct
      allow create: if isAdmin() || (
        request.resource.data.keys().hasAll(['date', 'time', 'source', 'status', 'totalTickets', 'createdAt', 'customerName', 'customerEmail', 'tickets', 'localizador']) &&
        request.resource.data.source == 'online' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.totalTickets > 0 &&
        request.resource.data.totalTickets <= 20
      );
    }
    
    match /slots/{slotId} {
      // Public can read capacities
      allow read: if true;
      
      // Admins can do anything
      allow update, delete: if isAdmin();
      allow create: if isAdmin() || true; // Let public create the slot counter if it doesn't exist yet
      
      // Public can increment bookedCount
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedCount']) &&
        request.resource.data.bookedCount > resource.data.bookedCount &&
        request.resource.data.bookedCount <= 20
      );
    }
  }
}
